{
    "compilerOptions": {
        "module": "esnext",
        "target": "es2015",
        "moduleResolution": "node",
        "allowSyntheticDefaultImports": true,
        "esModuleInterop": true,
        "downlevelIteration": true,
        "allowJs": true,
        "sourceMap": true,
        "outDir": "dist",
        "rootDirs": [
            "src"
        ],
        "baseUrl": ".",
        "lib": [
            "es2015",
            "es2016",
            "dom",
            "dom.iterable",
            "es2015.promise"
        ],
        "types": [
            "mocha"
        ]
    },
    "include": [
        "src/**/*.ts"
    ],
    "exclude": [
        "src/**/*.spec.ts",
        "node_modules",
        "**/*.js",
        "dist"
    ]
}
